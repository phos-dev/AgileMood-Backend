# Copy to .env for local non-Docker development
# Docker Compose sets these automatically

# PostgreSQL connection string
DATABASE_URL=postgresql://agilemood:agilemood@localhost:5432/agilemood

# JWT signing secret — CHANGE THIS in production
SECRET_KEY=dev-secret-key-change-in-prod

# Microsoft Teams integration
TEAMS_APP_ID=your-azure-app-registration-client-id
TEAMS_APP_SECRET=your-azure-app-registration-client-secret
TEAMS_REDIRECT_URI=https://yourdomain.com/auth/teams/callback
# TEAMS_BOT_TENANT=botframework.com        # default: multi-tenant prod
# TEAMS_BOT_TENANT=your-aad-tenant-id      # single-tenant dev (set to your AAD tenant ID)
# TEAMS_SERVICE_URL=https://smba.trafficmanager.net/apis  # default: global
# TEAMS_SERVICE_URL=https://smba.trafficmanager.net/amer  # Americas / Brazil
# TEAMS_SERVICE_URL=https://smba.trafficmanager.net/emea  # EMEA
# TEAMS_SERVICE_URL=https://smba.trafficmanager.net/apac  # APAC
